{
  "Logging": {
    "LogLevel": {
      //"Default": "Information",
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "authdb": "Host=localhost;Port=55432;Database=authdb;Username=postgres;Password=postgres"
  },
  "Auth": {
    "Jwt": {
      "Issuer": "eshop.gateway",
      "Audience": "eshop.api",
      "SigningKey": "CHANGE_ME_IN_USER_SECRETS_WITH_AT_LEAST_32_CHARACTERS",
      "AccessTokenMinutes": 15,
      "RefreshTokenDays": 14
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://eshop.example.com",
      "https://admin.eshop.example.com"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/catalog/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/catalog" }
        ]
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/inventory" }
        ]
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/order/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/order" }
        ]
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "catalog-api": {
            "Address": "http://catalog:8080"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "inventory-api": {
            "Address": "http://inventory:8080"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-api": {
            "Address": "http://order:8080"
          }
        }
      }
    }
  }
}

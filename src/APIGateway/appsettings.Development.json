{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "authdb": "Host=localhost;Port=55432;Database=authdb;Username=postgres;Password=postgres"
  },
  "Auth": {
    "Jwt": {
      "Issuer": "eshop.gateway",
      "Audience": "eshop.api",
      "SigningKey": "dev-signing-key-at-least-32-characters-long",
      "AccessTokenMinutes": 15,
      "RefreshTokenDays": 14
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "catalog-api": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "inventory-api": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-api": {
            "Address": "http://localhost:5003"
          }
        }
      }
    }
  }
}

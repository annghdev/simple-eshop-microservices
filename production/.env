# ===== Application images =====
APIGATEWAY_IMAGE=ghcr.io/your-org/eshop-apigateway:latest
CATALOG_IMAGE=ghcr.io/your-org/eshop-catalog:latest
INVENTORY_IMAGE=ghcr.io/your-org/eshop-inventory:latest
ORDER_IMAGE=ghcr.io/your-org/eshop-order:latest

# ===== Infrastructure images =====
POSTGRES_IMAGE=postgres:17.6
REDIS_IMAGE=redis:8.2
RABBITMQ_IMAGE=rabbitmq:4.2-management

# ===== Monitoring images =====
PROMETHEUS_IMAGE=prom/prometheus:v2.55.0
LOKI_IMAGE=grafana/loki:3.2.1
JAEGER_IMAGE=jaegertracing/all-in-one:1.62.0
TEMPO_IMAGE=grafana/tempo:2.6.1
GRAFANA_IMAGE=grafana/grafana:11.6.11
POSTGRES_EXPORTER_IMAGE=quay.io/prometheuscommunity/postgres-exporter:v0.16.0
REDIS_EXPORTER_IMAGE=oliver006/redis_exporter:v1.67.0

# ===== Host ports =====
APIGATEWAY_PORT=5000
CATALOG_PORT=5001
INVENTORY_PORT=5002
ORDER_PORT=5003
POSTGRES_PORT=55432
REDIS_PORT=56379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_METRICS_PORT=15692
PROMETHEUS_PORT=9090
LOKI_PORT=3100
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318
TEMPO_PORT=3200
TEMPO_OTLP_GRPC_PORT=4319
GRAFANA_PORT=3000
POSTGRES_EXPORTER_PORT=9187
REDIS_EXPORTER_PORT=9121

# ===== Runtime settings =====
ASPNETCORE_ENVIRONMENT=Production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
REDIS_PASSWORD=change-me-redis
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=change-me-rabbitmq
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

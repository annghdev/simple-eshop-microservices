# Must match ESHOP_APP_NETWORK_NAME in docker-composes/production/.env
ESHOP_APP_NETWORK_NAME=eshop-production-net

# Registry tags after `docker compose build` (optional; Coolify can build without pushing)
MONITORING_PROMETHEUS_IMAGE=eshop/monitoring-prometheus:local
MONITORING_LOKI_IMAGE=eshop/monitoring-loki:local
MONITORING_TEMPO_IMAGE=eshop/monitoring-tempo:local
MONITORING_GRAFANA_IMAGE=eshop/monitoring-grafana:local

JAEGER_IMAGE=jaegertracing/all-in-one:1.62.0
POSTGRES_EXPORTER_IMAGE=quay.io/prometheuscommunity/postgres-exporter:v0.16.0
REDIS_EXPORTER_IMAGE=oliver006/redis_exporter:v1.67.0

# Same credentials as production Postgres / Redis (exporters scrape via service name on shared network)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
REDIS_PASSWORD=change-me-redis

# Monitoring UI ports
PROMETHEUS_PORT=9090
LOKI_PORT=3100
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318
TEMPO_PORT=3200
TEMPO_OTLP_GRPC_PORT=4319
POSTGRES_EXPORTER_PORT=9187
REDIS_EXPORTER_PORT=9121
GRAFANA_PORT=3000

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Targets Up (App + Infra)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(up{job=~\"apigateway|catalog-api|inventory-api|order-api|postgres-exporter|rabbitmq|redis-exporter\"})",
          "instant": true,
          "editorMode": "code"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "max": 7,
          "min": 0,
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 6
              },
              {
                "color": "green",
                "value": 7
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "APIGateway Requests Per Second",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_request_duration_seconds_count{job=\"apigateway\",http_route!=\"/metrics\"}[1m]))",
          "legendFormat": "apigateway rps",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Exceptions Per Second (By Service)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate(dotnet_exceptions_total{job=~\"apigateway|catalog-api|inventory-api|order-api\"}[1m]))",
          "legendFormat": "{{job}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "CPU Usage % (By Service)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (job) (rate(dotnet_process_cpu_time_seconds_total{job=~\"apigateway|catalog-api|inventory-api|order-api\",cpu_mode=~\"user|system\"}[1m])) / max by (job) (dotnet_process_cpu_count{job=~\"apigateway|catalog-api|inventory-api|order-api\"})",
          "legendFormat": "{{job}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "RAM Working Set (By Service)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "dotnet_process_memory_working_set_bytes{job=~\"apigateway|catalog-api|inventory-api|order-api\"}",
          "legendFormat": "{{job}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "HTTP Request Rate (By Service)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (rate(http_server_request_duration_seconds_count{job=~\"apigateway|catalog-api|inventory-api|order-api\",http_route!=\"/metrics\"}[1m]))",
          "legendFormat": "{{job}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Recent Service Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{app=\"eshop-microservices\"}",
          "queryType": "range",
          "editorMode": "code"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 8,
      "title": "P95 Latency (By Service)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_server_request_duration_seconds_bucket{job=~\"apigateway|catalog-api|inventory-api|order-api\",http_route!=\"/metrics\"}[5m])))",
          "legendFormat": "{{job}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "HTTP Error Ratio (4xx/5xx)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (job) (rate(http_server_request_duration_seconds_count{job=~\"apigateway|catalog-api|inventory-api|order-api\",http_response_status_code=~\"4..\",http_route!=\"/metrics\"}[1m])) / clamp_min(sum by (job) (rate(http_server_request_duration_seconds_count{job=~\"apigateway|catalog-api|inventory-api|order-api\",http_route!=\"/metrics\"}[1m])), 1e-9)",
          "legendFormat": "{{job}} 4xx",
          "editorMode": "code"
        },
        {
          "refId": "B",
          "expr": "100 * sum by (job) (rate(http_server_request_duration_seconds_count{job=~\"apigateway|catalog-api|inventory-api|order-api\",http_response_status_code=~\"5..\",http_route!=\"/metrics\"}[1m])) / clamp_min(sum by (job) (rate(http_server_request_duration_seconds_count{job=~\"apigateway|catalog-api|inventory-api|order-api\",http_route!=\"/metrics\"}[1m])), 1e-9)",
          "legendFormat": "{{job}} 5xx",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "PostgreSQL Connections",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (datname) (pg_stat_database_numbackends{job=\"postgres-exporter\",datname!~\"template0|template1\"})",
          "legendFormat": "{{datname}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "PostgreSQL Transactions Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 32
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (datname) (rate(pg_stat_database_xact_commit{job=\"postgres-exporter\",datname!~\"template0|template1\"}[1m]) + rate(pg_stat_database_xact_rollback{job=\"postgres-exporter\",datname!~\"template0|template1\"}[1m]))",
          "legendFormat": "{{datname}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "title": "PostgreSQL Deadlocks Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 32
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (datname) (rate(pg_stat_database_deadlocks{job=\"postgres-exporter\",datname!~\"template0|template1\"}[5m]))",
          "legendFormat": "{{datname}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 13,
      "title": "RabbitMQ Queue Depth",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 40
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (queue) (rabbitmq_queue_messages{job=\"rabbitmq\",queue!=\"\"})",
          "legendFormat": "{{queue}}",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 14,

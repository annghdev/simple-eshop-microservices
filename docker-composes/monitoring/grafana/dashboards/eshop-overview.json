      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 48
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(redis_keyspace_hits_total{job=\"redis-exporter\"}[5m])) / clamp_min(sum(rate(redis_keyspace_hits_total{job=\"redis-exporter\"}[5m]) + rate(redis_keyspace_misses_total{job=\"redis-exporter\"}[5m])), 1)",

# ===== Application images (push to your registry for Coolify) =====
APIGATEWAY_IMAGE=ghcr.io/your-org/eshop-apigateway:latest
CATALOG_IMAGE=ghcr.io/your-org/eshop-catalog:latest
INVENTORY_IMAGE=ghcr.io/your-org/eshop-inventory:latest
ORDER_IMAGE=ghcr.io/your-org/eshop-order:latest
PAYMENT_IMAGE=ghcr.io/your-org/eshop-payment:latest
SHIPPING_IMAGE=ghcr.io/your-org/eshop-shipping:latest

# ===== Infrastructure images =====
POSTGRES_IMAGE=postgres:17.6
REDIS_IMAGE=redis:8.2
RABBITMQ_IMAGE=rabbitmq:4.2-management

# ===== Shared Docker network (same name in docker-composes/monitoring/.env) =====
ESHOP_APP_NETWORK_NAME=eshop-production-net

# Applications must reach the monitoring stack on this network (container names from monitoring compose).
JAEGER_OTLP_ENDPOINT=http://eshop-monitoring-jaeger:4317
TEMPO_OTLP_ENDPOINT=http://eshop-monitoring-tempo:4319
LOKI_ENDPOINT=http://eshop-monitoring-loki:3100

# ===== Host ports =====
APIGATEWAY_PORT=5000
CATALOG_PORT=5001
INVENTORY_PORT=5002
ORDER_PORT=5003
PAYMENT_PORT=5004
SHIPPING_PORT=5005
POSTGRES_PORT=55432
REDIS_PORT=56379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_METRICS_PORT=15692

# ===== Runtime settings =====
ASPNETCORE_ENVIRONMENT=Production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres
REDIS_PASSWORD=change-me-redis
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=change-me-rabbitmq
